<UserControl x:Class="ExcelBinder.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ExcelBinder.Views"
             xmlns:conv="clr-namespace:ExcelBinder.Converters"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <!-- Common Card Content Template -->
        <ControlTemplate x:Key="FeatureCardTemplate" TargetType="ContentControl">
            <Border Style="{StaticResource CardStyle}" Width="280" Height="200" Margin="0,0,20,20"
                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <Border.ContextMenu>
                    <ContextMenu Name="FeatureContextMenu" Opened="FeatureContextMenu_Opened"
                                 Tag="{Binding}"/>
                </Border.ContextMenu>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <DockPanel>
                        <Border Background="{StaticResource LightBackgroundBrush}" CornerRadius="4" Padding="6,2" DockPanel.Dock="Right">
                            <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TagTextBrush}"/>
                        </Border>
                        <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                    </DockPanel>

                    <TextBlock Grid.Row="1" Text="{Binding Description}" FontSize="13" Foreground="{StaticResource MutedTextBrush}" 
                               TextWrapping="Wrap" Margin="0,10,0,0" LineHeight="18"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Edit" Command="{Binding DataContext.EditFeatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                CommandParameter="{Binding}" Margin="0,0,10,0" Width="60" Height="32"/>
                        <Button Content="Open" Style="{StaticResource PrimaryButton}" 
                                Command="{Binding DataContext.SelectFeatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                CommandParameter="{Binding}" Width="80" Height="32"/>
                    </StackPanel>
                </Grid>
            </Border>
        </ControlTemplate>

        <DataTemplate x:Key="StaticDataTemplate">
            <ContentControl Template="{StaticResource FeatureCardTemplate}"/>
        </DataTemplate>

        <DataTemplate x:Key="LogicTemplate">
            <ContentControl Template="{StaticResource FeatureCardTemplate}"/>
        </DataTemplate>

        <DataTemplate x:Key="SchemaGenTemplate">
            <ContentControl Template="{StaticResource FeatureCardTemplate}"/>
        </DataTemplate>

        <DataTemplate x:Key="EnumTemplate">
            <ContentControl Template="{StaticResource FeatureCardTemplate}"/>
        </DataTemplate>

        <DataTemplate x:Key="ConstantsTemplate">
            <ContentControl Template="{StaticResource FeatureCardTemplate}"/>
        </DataTemplate>

        <local:DashboardItemTemplateSelector x:Key="DashboardItemSelector"
                                           StaticDataTemplate="{StaticResource StaticDataTemplate}"
                                           LogicTemplate="{StaticResource LogicTemplate}"
                                           SchemaGenTemplate="{StaticResource SchemaGenTemplate}"
                                           EnumTemplate="{StaticResource EnumTemplate}"
                                           ConstantsTemplate="{StaticResource ConstantsTemplate}"/>
    </UserControl.Resources>
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,5,0,30">
            <TextBlock Text="Excel Binder" FontSize="32" FontWeight="Bold" Padding="0,5,0,0" Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="Manage your data extraction and code generation features" FontSize="14" Foreground="{StaticResource MutedTextBrush}"/>

        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,15,0" Padding="0,0,15,0"
                    BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderBrush}">
                <DockPanel>
                    <Button DockPanel.Dock="Top" Content="+ 새 그룹"
                            Command="{Binding AddGroupCommand}"
                            Margin="0,0,0,10" Height="32"/>
                    <ListBox ItemsSource="{Binding Groups}"
                             SelectedItem="{Binding SelectedGroup}"
                             DisplayMemberPath="Name"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="새 그룹 만들기"
                                          Command="{Binding PlacementTarget.DataContext.AddGroupCommand,
                                                    RelativeSource={RelativeSource Self}}"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="이름변경"
                                                      Command="{Binding PlacementTarget.Tag.RenameGroupCommand,
                                                                RelativeSource={RelativeSource Self}}"
                                                      CommandParameter="{Binding}"
                                                      IsEnabled="{Binding IsAllGroup,
                                                                  Converter={StaticResource InverseBooleanConverter}}"/>
                                            <MenuItem Header="삭제"
                                                      Command="{Binding PlacementTarget.Tag.DeleteGroupCommand,
                                                                RelativeSource={RelativeSource Self}}"
                                                      CommandParameter="{Binding}"
                                                      IsEnabled="{Binding IsAllGroup,
                                                                  Converter={StaticResource InverseBooleanConverter}}"/>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Tag"
                                        Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <DockPanel Grid.Column="1">
                <Border DockPanel.Dock="Top" Margin="0,0,0,15"
                        Visibility="{Binding IsCustomGroupSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <TextBlock Text="{Binding SelectedGroupName}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                        <Button Content="Feature 관리" HorizontalAlignment="Right"
                                Command="{Binding ManageGroupMembersCommand}"
                                Style="{StaticResource SecondaryButton}" Width="140" Height="32"/>
                    </Grid>
                </Border>

                <ListBox ItemsSource="{Binding FilteredFeatures}" BorderThickness="0" Background="Transparent"
                         ItemTemplateSelector="{StaticResource DashboardItemSelector}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Grid>

        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,20,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Settings" Command="{Binding NavigateToSettingsCommand}" Width="100" Height="36" Margin="0,0,10,0"/>
                    <Button Content="Refresh" Command="{Binding RefreshFeaturesCommand}" Width="100" Height="36"/>
                </StackPanel>
                <Button Content="+ Create New Feature" Style="{StaticResource SecondaryButton}" 
                        Command="{Binding CreateFeatureCommand}" Width="180" Height="36" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
