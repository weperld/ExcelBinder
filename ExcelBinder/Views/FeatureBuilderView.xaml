<UserControl x:Class="ExcelBinder.Views.FeatureBuilderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExcelBinder.Views"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000" Background="White">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,5,0,25" LastChildFill="False">
            <TextBlock Text="Feature 빌더" FontSize="28" FontWeight="Bold" Padding="0,5,0,0"
                       Foreground="{DynamicResource PrimaryBrush}" DockPanel.Dock="Left"/>
            <Button Content="?" DockPanel.Dock="Right" VerticalAlignment="Center"
                    Width="28" Height="28" FontWeight="Bold" FontSize="14"
                    ToolTip="이 화면 가이드 보기"
                    Click="HelpButton_Click" Tag="feature-builder"/>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,-10,0" Padding="0,10,10,0">
            <StackPanel>
                <!-- Basic Info -->
                <GroupBox>
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="일반 정보"/>
                            <Button Style="{StaticResource HelpButtonStyle}" ToolTipService.ToolTip="{StaticResource GeneralInfoHelp}"/>
                        </StackPanel>
                    </GroupBox.Header>
                    <StackPanel Margin="5">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" MinWidth="80"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="Feature ID:" FontWeight="SemiBold"/>
                                <Button Style="{StaticResource HelpButtonStyle}" ToolTipService.ToolTip="{StaticResource FeatureIdHelp}"/>
                            </StackPanel>
                            <TextBox Grid.Column="1" Text="{Binding Feature.Id}" Margin="0,0,20,0"/>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="카테고리:" FontWeight="SemiBold"/>
                                <Button Style="{StaticResource HelpButtonStyle}" ToolTipService.ToolTip="{StaticResource CategoryHelp}"/>
                            </StackPanel>
                            <ComboBox Grid.Column="3" SelectedValue="{Binding Category}" SelectedValuePath="Content">
                                <ComboBoxItem Content="StaticData"/>
                                <ComboBoxItem Content="Logic"/>
                                <ComboBoxItem Content="SchemaGen"/>
                                <ComboBoxItem Content="Enum"/>
                                <ComboBoxItem Content="Constants"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="표시 이름:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1" Text="{Binding Feature.Name}"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="설명:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1" Text="{Binding Feature.Description}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="기본 네임스페이스:" FontWeight="SemiBold"/>
                                <Button Style="{StaticResource HelpButtonStyle}" ToolTipService.ToolTip="{StaticResource NamespaceHelp}"/>
                            </StackPanel>
                            <TextBox Grid.Column="1" Text="{Binding Feature.DefaultNamespace}"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Paths -->
                <GroupBox>
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="파일 경로 설정"/>
                            <Button Style="{StaticResource HelpButtonStyle}" ToolTipService.ToolTip="{StaticResource FilePathsHelp}"/>
                        </StackPanel>
                    </GroupBox.Header>
                    <StackPanel Margin="5">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="Excel 디렉터리:" FontWeight="SemiBold"/>
                                <Button Style="{StaticResource HelpButtonStyle}" ToolTipService.ToolTip="{StaticResource ExcelPathHelp}"/>
                            </StackPanel>
                            <TextBox Grid.Column="1" Text="{Binding Feature.ExcelPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="찾아보기" Command="{Binding BrowseExcelPathCommand}" Width="80" Margin="10,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,10" Visibility="{Binding IsSchemaPathVisible, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="Schema 디렉터리:" FontWeight="SemiBold"/>
                                <Button Style="{StaticResource HelpButtonStyle}" ToolTipService.ToolTip="{StaticResource SchemaPathHelp}"/>
                            </StackPanel>
                            <TextBox Grid.Column="1" Text="{Binding Feature.SchemaPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="찾아보기" Command="{Binding BrowseSchemaPathCommand}" Width="80" Margin="10,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,10" Visibility="{Binding IsExportPathVisible, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="Export 디렉터리:" FontWeight="SemiBold"/>
                                <Button Style="{StaticResource HelpButtonStyle}" ToolTipService.ToolTip="{StaticResource ExportPathHelp}"/>
                            </StackPanel>
                            <TextBox Grid.Column="1" Text="{Binding Feature.ExportPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="찾아보기" Command="{Binding BrowseExportPathCommand}" Width="80" Margin="10,0,0,0"/>
                        </Grid>

                        <Grid Visibility="{Binding IsScriptsPathVisible, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="Scripts 디렉터리:" FontWeight="SemiBold"/>
                                <Button Style="{StaticResource HelpButtonStyle}" ToolTipService.ToolTip="{StaticResource ScriptsPathHelp}"/>
                            </StackPanel>
                            <TextBox Grid.Column="1" Text="{Binding Feature.ScriptsPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="찾아보기" Command="{Binding BrowseScriptsPathCommand}" Width="80" Margin="10,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Types -->
                <GroupBox Visibility="{Binding IsTypeMappingsVisible, Converter={StaticResource BoolToVis}}">
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="타입 매핑"/>
                            <Button Style="{StaticResource HelpButtonStyle}" ToolTipService.ToolTip="{StaticResource TypeMappingsHelp}"/>
                        </StackPanel>
                    </GroupBox.Header>
                    <StackPanel Margin="5">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Excel 타입" FontWeight="Bold" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="매핑된 C# 타입" FontWeight="Bold" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center"/>
                        </Grid>
                        
                        <ItemsControl ItemsSource="{Binding TypeMappings}" Margin="0,0,0,15">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox ItemsSource="{Binding DataContext.AvailableTypes, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                  SelectedItem="{Binding Key, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,5,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Margin="5,0"/>
                                        <Button Grid.Column="2" Content="삭제" Command="{Binding DataContext.RemoveMappingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" Width="80" Margin="5,0,0,0" Foreground="{DynamicResource DangerBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ 매핑 추가" Command="{Binding AddMappingCommand}" Width="150" Height="32" Margin="0,0,10,0"/>
                            <Button Content="기본 타입 채우기" Command="{Binding AddDefaultMappingsCommand}" Width="180" Height="32"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Templates -->
                <GroupBox Visibility="{Binding IsTemplatesVisible, Converter={StaticResource BoolToVis}}">
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="템플릿 설정"/>
                            <Button Style="{StaticResource HelpButtonStyle}" ToolTipService.ToolTip="{StaticResource TemplatesConfigurationHelp}"/>
                        </StackPanel>
                    </GroupBox.Header>
                    <StackPanel Margin="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="데이터 템플릿 (.liquid):" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1" Text="{Binding Feature.Templates.DataClass, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="찾아보기" Command="{Binding BrowseDataTemplateCommand}" Width="80" Height="32" Margin="10,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Output Options -->
                <GroupBox Visibility="{Binding IsOutputOptionsVisible, Converter={StaticResource BoolToVis}}">
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="출력 옵션"/>
                            <Button Style="{StaticResource HelpButtonStyle}" ToolTipService.ToolTip="{StaticResource OutputOptionsHelp}"/>
                        </StackPanel>
                    </GroupBox.Header>
                    <StackPanel Margin="5">
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="파일 확장자:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <TextBox Grid.Column="1" Text="{Binding Feature.OutputOptions.Extension}"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="지원 포맷:" Width="150" FontWeight="SemiBold"/>
                            <CheckBox Content="Binary (.bytes)" IsChecked="{Binding Feature.OutputOptions.SupportsBinary}" Margin="0,0,20,0"/>
                            <CheckBox Content="JSON (.json)" IsChecked="{Binding Feature.OutputOptions.SupportsJson}"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,20,0,0" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="취소" Command="{Binding CancelCommand}" Width="100" Height="36" Margin="0,0,12,0"/>
                <Button Content="Feature 정의 저장" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}" Width="200" Height="36"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
