<Window x:Class="ExcelBinder.Views.GuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ExcelBinder 사용 가이드"
        Width="1410" Height="845" MinWidth="1085" MinHeight="650"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Custom TreeViewItem: 기본 파란 하이라이트 제거 + 부드러운 hover/select 표시 -->
        <Style x:Key="GuideTreeViewItemStyle" TargetType="{x:Type TreeViewItem}">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TreeViewItem}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border x:Name="HeaderBorder"
                                    Grid.Row="0"
                                    Background="Transparent"
                                    CornerRadius="4"
                                    Padding="10,5"
                                    Margin="0,1"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter x:Name="PART_Header"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost"
                                            Grid.Row="1"
                                            Margin="14,0,0,0"
                                            Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True" SourceName="HeaderBorder">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#EEF2FA"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#DDE5F5"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsSelectionActive" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#E5EAF3"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 사이드바 트리 -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="{StaticResource LightBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <TreeView x:Name="TopicTree"
                      ItemsSource="{Binding Categories}"
                      BorderThickness="0"
                      Background="Transparent"
                      Padding="6"
                      ItemContainerStyle="{StaticResource GuideTreeViewItemStyle}"
                      SelectedItemChanged="TopicTree_SelectedItemChanged">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Topics}">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <HierarchicalDataTemplate.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}" FontSize="13"/>
                            </DataTemplate>
                        </HierarchicalDataTemplate.ItemTemplate>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>

        <!-- 본문 -->
        <FlowDocumentScrollViewer x:Name="DocumentViewer"
                                  Grid.Row="0" Grid.Column="1"
                                  Document="{Binding CurrentDocument}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="24,20"
                                  IsToolBarVisible="False"
                                  PreviewMouseWheel="DocumentViewer_PreviewMouseWheel"/>

        <!-- 하단 바 -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Background="White"
                Padding="16,10">
            <DockPanel LastChildFill="False">
                <CheckBox Content="다시 보지 않기"
                          IsChecked="{Binding DoNotShowAgain}"
                          Visibility="{Binding IsFirstRunMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                          VerticalAlignment="Center"
                          DockPanel.Dock="Left"/>
                <Button Content="닫기"
                        Command="{Binding CloseCommand}"
                        Width="90" Height="32"
                        DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
